# Database connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tenantcore_platform
DB_USER=tenantcore_app
DB_PASSWORD=change_me
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=change_me_admin

# Environment: dev | staging | prod
ENVIRONMENT=dev

# Optional application schema
DB_SCHEMA=public

# Seed super admin defaults
SEED_SUPER_ADMIN_EMAIL=admin@tenantcore.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_FIRST_NAME=Super
SEED_SUPER_ADMIN_LAST_NAME=Admin

# Remote deployment over SSH (used by scripts/ssh/deploy-db.sh)
SSH_HOST=example.com
SSH_PORT=22
SSH_USER=ubuntu
SSH_REMOTE_DIR=/opt/tenantcore-platform/apps
